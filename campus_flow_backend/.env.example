# ╔═══════════════════════════════════════════════════════════════════╗
# ║              CampusFlow Backend — Environment Config             ║
# ╠═══════════════════════════════════════════════════════════════════╣
# ║  Copy this file to .env and fill in your values.                 ║
# ║  cp .env.example .env                                            ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ── AI Provider ───────────────────────────────────────────────
# Currently using Gemini only
AI_PROVIDER=gemini


# ── AWS CREDENTIALS ─────────────────────────────────────────────────
# Used for: DynamoDB, S3, Rekognition, AND Bedrock (if AI_PROVIDER=bedrock)
# Get from: AWS Console → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-south-1

# ── AWS SERVICES ─────────────────────────────────────────────────────
S3_BUCKET_NAME=campusflow-files
DYNAMODB_TABLE_PREFIX=campusflow

# ── APP CONFIG ───────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=change-this-to-a-random-string-in-production
MAX_NOTIFICATION_BATCH=100
DIGEST_HOUR=8


GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://YOUR_EC2_IP/api/classroom/oauth/callback