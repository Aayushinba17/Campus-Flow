# ╔═══════════════════════════════════════════════════════════════════╗
# ║              CampusFlow Backend — Environment Config             ║
# ╠═══════════════════════════════════════════════════════════════════╣
# ║  Copy this file to .env and fill in your values.                 ║
# ║  cp .env.example .env                                            ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ── AI PROVIDER ──────────────────────────────────────────────────────
# Choose your AI backend:
#   "gemini"     → Use Google Gemini (FREE API key from Google AI Studio)
#   "bedrock"    → Use Amazon Bedrock (FREE with hackathon credits!)
#   "anthropic"  → Use Anthropic API directly (needs separate API key)
#
AI_PROVIDER=gemini

# ── GEMINI (only if AI_PROVIDER=gemini) ──────────────────────────────
# Get your FREE key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxx

# ── ANTHROPIC (only if AI_PROVIDER=anthropic) ────────────────────────
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# ── AMAZON BEDROCK (only if AI_PROVIDER=bedrock) ─────────────────────
# Uses your same AWS credentials below — no extra key needed!
# Region MUST be one where Claude is available on Bedrock.
# Recommended: us-east-1 (N. Virginia) — has all Claude models.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20250514

# ── AWS CREDENTIALS ─────────────────────────────────────────────────
# Used for: DynamoDB, S3, Rekognition, AND Bedrock (if AI_PROVIDER=bedrock)
# Get from: AWS Console → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-south-1

# ── AWS SERVICES ─────────────────────────────────────────────────────
S3_BUCKET_NAME=campusflow-files
DYNAMODB_TABLE_PREFIX=campusflow

# ── APP CONFIG ───────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=change-this-to-a-random-string-in-production
MAX_NOTIFICATION_BATCH=100
DIGEST_HOUR=8
